{
  "name": "klab-randevu-backend",
  "version": "1.0.0",
  "description": "Kuveyt Türk AI Lab - Oda Kiralama Sistemi Backend",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/db/*.sql dist/db/ && mkdir -p dist/db/migrations && (cp src/db/migrations/*.sql dist/db/migrations/ 2>/dev/null || true)",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "keys:generate": "tsx scripts/generate-keys.ts",
    "db:init": "tsx scripts/init-db.ts",
    "lint": "eslint src",
    "setup": "npm run keys:generate && npm run db:init",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:perf": "vitest run tests/perf-queries.test.ts"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "compression": "1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "pg": "^8.21.0",
    "prom-client": "15.1.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "qs": "^6.15.2"
  }
}
