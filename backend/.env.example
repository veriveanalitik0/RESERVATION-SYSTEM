# ============================================================
# Kuveyt Türk AI Lab - Backend Environment Variables
# ============================================================
# UYARI (data_security.md §1): Bu dosyayı .env olarak kopyalayın
# ve gerçek değerlerle doldurun. .env dosyasını ASLA commit etmeyin.
# Production'da kurumsal kasa (Vault/KMS) kullanın.
# ============================================================

# Server
NODE_ENV=development
PORT=4000
HOST=127.0.0.1

# CORS — Frontend origin (wildcard yasak — app_security §6)
FRONTEND_ORIGIN=http://localhost:5173

# JWT Keys (RS256 — HS256 yasak — app_security §4)
# Bu yolları değiştirmeyin; `npm run keys:generate` ile üretilir
USER_JWT_PRIVATE_KEY_PATH=./keys/user_private.pem
USER_JWT_PUBLIC_KEY_PATH=./keys/user_public.pem
ADMIN_JWT_PRIVATE_KEY_PATH=./keys/admin_private.pem
ADMIN_JWT_PUBLIC_KEY_PATH=./keys/admin_public.pem

# JWT TTL (saniye)
USER_ACCESS_TOKEN_TTL=900
USER_REFRESH_TOKEN_TTL=604800
ADMIN_ACCESS_TOKEN_TTL=900
ADMIN_REFRESH_TOKEN_TTL=604800

# JWT Audience & Issuer
JWT_ISSUER=klab-randevu
USER_JWT_AUDIENCE=klab-user
ADMIN_JWT_AUDIENCE=klab-admin

# Database — PostgreSQL (ZORUNLU). Sistem yalnız pg ile çalışır.
DATABASE_URL=postgres://klab:klab_dev_password@localhost:5432/klab
# Prod'da TLS zorunlu (managed/uzak Postgres). İç-ağ sidecar-TLS ile bilinçli
# kapatmak için: PGSSL=disable  (veya DATABASE_URL'a ?sslmode=disable).
# Bağlantı havuzu + zaman aşımları (ms) — hepsi opsiyonel, kodda makul varsayılan var.
# DB_POOL_MAX=10
# DB_STATEMENT_TIMEOUT_MS=15000   # pg server-side statement_timeout
# DB_QUERY_TIMEOUT_MS=15000       # node-pg client query_timeout
# DB_CONNECT_TIMEOUT_MS=5000
# DB_IDLE_TIMEOUT_MS=30000

# CSRF
CSRF_SECRET=CHANGE_ME_RUNTIME_GENERATED_VALUE_AT_LEAST_32_CHARS_LONG

# At-rest şifreleme anahtarı (admin TOTP secret vb. — AES-256-GCM).
# 64 haneli hex (openssl rand -hex 32) ÖNERİLİR. Boşsa CSRF_SECRET'tan türetilir.
# ENCRYPTION_KEY=

# Demo seed prod guard — prod'da seed yalnız bu açıkken çalışır (bilinçli).
# ALLOW_PROD_SEED=false

# Brute force koruması
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=10

# Log seviyesi
LOG_LEVEL=info

# Observability — OpenTelemetry (otel.ts). VARSAYILAN KAPALI (demo modu).
# OTEL_DISABLED=1                                  # '1' → trace tamamen kapalı
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # set edilince OTLP exporter aktif (Jaeger/Tempo vb.)
# OTEL_SERVICE_NAME=klab-randevu                   # trace'lerde görünen servis adı

# Prometheus /api/metrics erişim token'ı (Bearer). Prod'da scrape için zorunlu;
# boşsa /api/metrics prod'da erişime kapalı kalır. Üret: openssl rand -hex 24
# METRICS_TOKEN=

# Embedding modeli (transformers) cache dizini. node_modules salt-okunur olduğunda
# (prod container) yazılabilir volume'a yönlendirir. Prod compose'da /app/data/models.
# MODEL_CACHE_DIR=

# Bakım / Audit retention (data_security §11) — audit_logs tablo şişmesini önler
# Yaş bazlı retention (gün). 0 = silme. Bankacılık tipik 365; demo/dev için kısalt (örn. 30).
AUDIT_RETENTION_DAYS=365
# Hacim sınırı — en yeni N audit kaydı tutulur (yüksek log üretiminde tablo şişmesin). 0 = sınırsız.
AUDIT_MAX_ROWS=200000
# Silme sonrası VACUUM ile ölü tuple alanını geri kazan. 'false' = kapat.
AUDIT_VACUUM=true

# Görsel üretimi (gorsel_uretim entegrasyonu)
# Feature flag: 'false' → /user/visuals uçları 503, dış görsel/çeviri API'sine
# hiç istek çıkmaz (prod'da dış bağımlılık istemiyorsan kapat). Varsayılan açık.
# FEATURE_VISUALS=false
# Provider: 'huggingface' (varsayılan, ücretsiz) | 'pollinations' | 'gemini'
IMAGE_PROVIDER=huggingface
# --- Hugging Face (ÖNERİLEN, ücretsiz) — FLUX.1-schnell ---
# huggingface.co/settings/tokens → "Read" rolünde ücretsiz token (hf_...) oluştur.
# Ücretsiz tier rate-limit'li ama API key maliyeti yok. Token yalnız sunucuda kalır.
HUGGINGFACE_API_KEY=
# (opsiyonel) Farklı bir text-to-image modeli / kendi endpoint'in:
# HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# HUGGINGFACE_API_BASE=https://router.huggingface.co/hf-inference/models
# --- Pollinations (alternatif) ---
# Yeni API anonim erişimde 402 (ödeme) veriyor → ücretsiz token gerekir.
# auth.pollinations.ai üzerinden GitHub ile ücretsiz token al.
# POLLINATIONS_TOKEN=
# --- Gemini 2.5 Flash Image (alternatif) — 500 görsel/gün ücretsiz ---
# GEMINI_API_KEY=
# UYARI (data_security §8): görsel üretimi proje fikrini üçüncü-taraf AI servisine gönderir.
# Production'da kurumsal-gated/self-hosted model + PII scrubber gerekir.
