# syntax=docker/dockerfile:1
# Frontend PRODUCTION image — vite static build → nginx ile serve + /api reverse proxy.
# Build context = repo KÖKÜ (shared/ tip kaynağı için):
#   docker build -f frontend/Dockerfile.prod -t klab-frontend:prod .

# ---- Stage 1: builder — vite static build ----
FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
# Paylaşılan tip kaynağı (tsconfig include `../shared/index.d.ts` → /shared).
COPY shared /shared
RUN npm run build

# ---- Stage 2: runtime — nginx (statik + API proxy) ----
# NON-ROOT: nginx-unprivileged master'ı root değil 'nginx' (uid 101) olarak
# çalışır ve ayrıcalıksız 8080 portunu dinler (container-escape blast-radius
# daralır — app_security §4). Yazılabilir pid/cache yolları /tmp altındadır.
FROM nginxinc/nginx-unprivileged:1.27-alpine AS runtime
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 8080
