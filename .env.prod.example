# Production ortam değişkenleri — kopyala: cp .env.prod.example .env.prod
# .env.prod ASLA commit edilmez (.gitignore + .dockerignore kapsamında).
# Çalıştırma: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- PostgreSQL ---
POSTGRES_USER=klab
POSTGRES_PASSWORD=__GÜÇLÜ_RASTGELE_PAROLA__
POSTGRES_DB=klab
# NOT: Backend DATABASE_URL'ı prod'da AYRICA verilmez — docker-compose.prod.yml
# bunu POSTGRES_* değişkenlerinden türetir:
#   postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Uygulama ---
# Frontend'in servis edileceği genel origin (CORS + cookie domain için).
FRONTEND_ORIGIN=https://randevu.klab.example
# CSRF imza sırrı — min 32 karakter. Üret: openssl rand -base64 48
CSRF_SECRET=__OPENSSL_RAND_BASE64_48__
# At-rest şifreleme anahtarı (admin TOTP secret — AES-256-GCM). Üret: openssl rand -hex 32
ENCRYPTION_KEY=__OPENSSL_RAND_HEX_32__
# İlk-kurulum bootstrap admin — DB boşsa backend boot'ta OTOMATİK oluşturur
# (manuel seed adımı gerekmez). Parolayı güçlü ver: openssl rand -base64 18
# Boş bırakılırsa varsayılan parola kullanılır + LOUD uyarı loglanır.
BOOTSTRAP_ADMIN_EMAIL=admin@klab.example
BOOTSTRAP_ADMIN_PASSWORD=__GÜÇLÜ_RASTGELE_PAROLA__
# Dışarı açılacak HTTP portu (TLS termination önünde bir LB varsa 80 kalır).
HTTP_PORT=80
LOG_LEVEL=info
# Saat dilimi — randevu/cron tarih hesapları bu dilime göre çalışır.
TZ=Europe/Istanbul
# Prometheus /api/metrics erişim token'ı (scrape config bearer). Üret: openssl rand -hex 24
METRICS_TOKEN=__OPENSSL_RAND_HEX_24__
# Veritabanı TLS: paketli (compose-içi) postgres TLS SUNMAZ → varsayılan 'disable'
# (aksi halde backend bağlanamaz, stack ayağa kalkmaz). Managed/uzak Postgres + TLS
# kullanıyorsan bu satırı boş bırak (veya kaldır) ya da DATABASE_URL'a sslmode ekle.
PGSSL=disable

# --- Observability (OpenTelemetry) — opsiyonel, varsayılan KAPALI ---
# OTEL_EXPORTER_OTLP_ENDPOINT set edilirse trace exporter aktifleşir.
# OTEL_DISABLED=1
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=klab-randevu

# --- Görsel üretimi — varsayılan KAPALI (prod'da dış API bağımlılığı yok) ---
# Açmak için: FEATURE_VISUALS=true + aşağıdaki sağlayıcı anahtarını doldur,
# ardından stack'i --build ile yeniden ayağa kaldır (frontend flag'i build-time gömülür).
# FEATURE_VISUALS=true
# IMAGE_PROVIDER=huggingface
# huggingface.co/settings/tokens → ücretsiz "Read" token (hf_...). YALNIZ server-side.
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxx
# Alternatif sağlayıcılar (IMAGE_PROVIDER değiştirip ilgili anahtarı doldur):
# POLLINATIONS_TOKEN=
# GEMINI_API_KEY=

# NOT: JWT anahtarları env'de DEĞİL — backend/keys/*.pem dosyaları salt-okunur
# volume ile mount edilir. Üret: cd backend && npm run keys:generate
